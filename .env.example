# ===========================================
# az-site Environment Configuration
# ===========================================
# Only fill the section matching your LLM provider in persona.config.ts

# --- OpenAI (also works with DeepSeek, Groq, Ollama, Ark) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=              # Optional: override for compatible APIs
OPENAI_MODEL=gpt-4o           # Default model

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini ---
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# --- TTS (optional — leave empty to use browser Web Speech API) ---
TTS_PROVIDER=                 # "openai" | "elevenlabs" | empty for browser native
TTS_API_KEY=

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=
